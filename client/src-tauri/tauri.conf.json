{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pix Stream",
  "version": "0.1.0",
  "identifier": "app.pixstream",
  "build": {
    "beforeDevCommand": "ng serve --hmr",
    "devUrl": "http://localhost:6200",
    "beforeBuildCommand": "npm run build -- --configuration=production",
    "frontendDist": "../dist/angular-momentum/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Pix Stream",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "appimage",
      "msi"
    ],
    "category": "Photography",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "Developer ID Application: Kevin Duda (7386GL7C2C)",
      "entitlements": "entitlements.distribute.plist",
      "dmg": {
        "background": "dmg_background.png"
      }
    },
    "iOS": {
      "bundleVersion": "1"
    },
    "android": {
      "minSdkVersion": 35,
      "versionCode": 1
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
