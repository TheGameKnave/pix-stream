RewriteEngine On

# API routing
RewriteRule ^api/manifest$ api/manifest.php [L,QSA]
RewriteRule ^api/config$ api/config.php [L,QSA]
RewriteRule ^api/auth/(.*)$ api/auth.php/$1 [L,QSA]
RewriteRule ^api/tags$ api/tags.php [L,QSA]
RewriteRule ^api/tags/(.*)$ api/tags.php/$1 [L,QSA]
RewriteRule ^api/upload$ api/upload.php [L,QSA]
RewriteRule ^api/status$ api/status.php [L,QSA]
RewriteRule ^api/logo$ api/logo.php [L,QSA]
RewriteRule ^api/favicon$ api/favicon.php [L,QSA]
RewriteRule ^api/watermark$ api/watermark.php [L,QSA]
RewriteRule ^api/delete$ api/delete.php [L,QSA]
RewriteRule ^api/update$ api/update.php [L,QSA]

# Serve images from storage (with .gif.jpg static fallback for thumbnails)
RewriteCond %{DOCUMENT_ROOT}/storage/thumbnails/$1 -f
RewriteRule ^api/image/thumb/(.*)$ /storage/thumbnails/$1 [L]
RewriteCond %{DOCUMENT_ROOT}/storage/thumbnails/$1.jpg -f
RewriteRule ^api/image/thumb/(.*)$ /storage/thumbnails/$1.jpg [L]
# Try processed first (has banner/resize), fall back to originals
RewriteCond %{DOCUMENT_ROOT}/storage/processed/$1 -f
RewriteRule ^api/image/full/(.*)$ /storage/processed/$1 [L]
RewriteRule ^api/image/full/(.*)$ /storage/originals/$1 [L]

# Serve favicon at domain root (browsers request this automatically for every page)
RewriteRule ^favicon\.(ico|svg)$ api/serve-favicon.php [L]

# Block direct access to config files
RewriteRule ^config/ - [F,L]
RewriteRule ^lib/ - [F,L]
RewriteRule \.password$ - [F,L]

# Angular SPA fallback — serve index.html for all non-file, non-API routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]

# PHP settings
php_value upload_max_filesize 50M
php_value post_max_size 55M
