{
  "name": "photo-stream",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx concurrently \"npm run client\" \"npm run server\"",
    "client": "cd client && ng serve --configuration development",
    "server": "/opt/homebrew/bin/php -S localhost:8080 -t server/ server/router.php",
    "build": "cd client && npm run build",
    "build:prod": "cd client && npm run build -- --configuration production",
    "test": "cd client && npm test",
    "prepare": "npx --yes is-ci || husky || true"
  },
  "workspaces": [
    "./client"
  ],
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "typescript": "~5.9.3"
  }
}
